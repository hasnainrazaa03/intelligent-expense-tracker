generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  email     String     @unique
  password  String
  isVerified      Boolean   @default(false)
  verificationOtp String?
  otpExpires      DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorOtp     String?
  twoFactorOtpExpires DateTime?
  loginAttempts   Int       @default(0)
  lockUntil       DateTime?
  resetToken      String?
  resetTokenExpires DateTime?
  // Bumped on password reset; embedded in issued JWTs and checked on each
  // authenticated request so old sessions are invalidated (SRV-M2).
  tokenVersion    Int       @default(0)
  // Per-account failed-OTP counter to complement the per-IP limiter (SRV-M4).
  otpAttempts     Int       @default(0)
  expenses  Expense[]
  incomes   Income[]
  budgets   Budget[]
  semesters Semester[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Expense {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  amount           Int    // integer cents
  category         String
  date             DateTime @db.Date
  paymentMethod    String?
  notes            String?
  originalAmount   Int?   // integer cents
  originalCurrency String?
  isRecurring      Boolean? @default(false)
  tags             String[]
  metadata         Json?
  taxCategory      String?
  isTaxDeductible  Boolean? @default(false)
  splitParticipants String[]
  splitShares      Int[]  // integer cents
  receiptText      String?
  receiptFileName  String?
  // Optional: tags this expense to a shared household so members can pool it.
  householdId      String?  @db.ObjectId
  // Idempotency key for offline-queued creates: replaying the same key returns
  // the existing row instead of creating a duplicate.
  clientRequestId  String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String   @db.ObjectId
  @@index([userId])
  @@index([userId, date])
  @@index([userId, category, date])
  @@index([householdId])
  @@index([userId, clientRequestId])
}

model Income {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  amount           Int    // integer cents
  category         String
  date             DateTime @db.Date
  notes            String?
  originalAmount   Int?   // integer cents
  originalCurrency String?
  tags             String[]
  metadata         Json?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String   @db.ObjectId
  @@index([userId])
  @@index([userId, date])
}

model Budget {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  category String
  amount   Int // integer cents
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String @db.ObjectId

  @@unique([userId, category], name: "userId_category")
  @@index([userId])
}

model Semester {
  // MongoDB MUST have a single _id primary key
  id_internal  String @id @default(auto()) @map("_id") @db.ObjectId
  
  id           String // This is your 'fall-2025' string
  name         String
  totalTuition Int // integer cents
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String @db.ObjectId
  installments TuitionInstallment[]

  // Use @@unique instead of @@id for composite uniqueness in MongoDB
  @@unique([id, userId], name: "id_userId")
  @@index([userId])
}

model TuitionInstallment {
  // autoincrement() is not supported in MongoDB
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  amount         Int // integer cents
  status         String
  expenseId      String?
  paidDate       DateTime? @db.Date
  
  // Relating to Semester's custom unique constraint
  semester       Semester  @relation(fields: [semesterId, semesterUserId], references: [id, userId], onDelete: Cascade)
  semesterId     String
  semesterUserId String    @db.ObjectId
  @@index([semesterId, semesterUserId])
}
model Household {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  ownerId   String            @db.ObjectId
  createdAt DateTime          @default(now())
  members   HouseholdMember[]
  @@index([ownerId])
}

model HouseholdMember {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId  String    @db.ObjectId
  // null while an emailed invite hasn't been accepted (or the email isn't a user yet)
  userId       String?   @db.ObjectId
  invitedEmail String
  role         String    @default("member") // 'owner' | 'member'
  status       String    @default("invited") // 'invited' | 'active'
  createdAt    DateTime  @default(now())
  @@index([householdId])
  @@index([userId])
  @@index([invitedEmail])
}

model Receipt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  expenseId String   @unique @db.ObjectId
  userId    String   @db.ObjectId
  // Downscaled JPEG as a data URL (kept out of the /all payload so lists stay lean).
  image     String
  createdAt DateTime @default(now())
  @@index([userId])
}
